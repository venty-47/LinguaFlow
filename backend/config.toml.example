[database]
host = "localhost"
port = "5432"
user = "postgres"
password = "postgres"
dbname = "gugudu"

[redis]
host = "localhost"
port = "6379"
password = ""

[jwt]
secret = "your-secret-key-here"

[server]
port = "8080"
gin_mode = "debug"

[cors]
allowed_origins = "http://localhost:3000"

[translation]
# 百度翻译 API (https://fanyi-api.baidu.com/)
baidu_appid = ""
baidu_secret = ""

# 百度智能云文本翻译-词典版 API Key / Secret Key
baidu_dict_api_key = ""
baidu_dict_secret_key = ""

# 有道翻译 API (https://ai.youdao.com/)
youdao_appkey = ""
youdao_appsecret = ""

[ai]
enabled = false
# MiMo OpenAI-compatible chat completions base URL
base_url = "https://api.xiaomimimo.com/v1"
# Leave empty to reuse [tts].api_key.
api_key = ""
model = "mimo-v2.5-pro"
request_timeout_seconds = 20

[tts]
enabled = false
# MiMo OpenAI-compatible chat completions base URL
base_url = "https://api.xiaomimimo.com/v1"
api_key = ""
model = "mimo-v2.5-tts"
voice = "Chloe"
response_format = "wav"
instructions = "Speak clearly for English learners with natural pauses and a neutral American accent."
cache_dir = "storage/tts"
request_timeout_seconds = 30
max_input_length = 3000

[rss]
enabled = true
import_token = "change-me-rss-import-token"
# Optional. Use a local proxy when RSS sources are not reachable directly.
# proxy = "http://127.0.0.1:7897"
user_agent = "GuGuDu RSS Importer/1.0"
request_timeout_seconds = 15
max_items_per_feed = 10

[ao3]
# Optional. AO3 can use a different local proxy/rule than RSS imports.
proxy = "http://127.0.0.1:7897"
request_timeout_seconds = 45

[video_learning]
enabled = true
storage_dir = "storage/videos"
audio_dir = "storage/video-audio"
transcript_dir = "storage/video-transcripts"
max_upload_mb = 300
max_duration_seconds = 3600
allowed_extensions = ".mp4,.mov,.m4v,.webm,.mp3,.m4a"
processing_timeout_seconds = 1800
# Default local option: FunASR exposes an OpenAI-compatible endpoint.
# Start it with: funasr-server --model sensevoice --device cpu
transcription_provider = "funasr"
transcription_base_url = "http://localhost:8000/v1"
transcription_api_key = ""
transcription_model = "sensevoice"
max_audio_upload_mb = 500

[[rss.feeds]]
name = "VOA Learning English - Science & Technology"
url = "https://learningenglish.voanews.com/api/zmg_pl-vomx-tpeymtm"
source = "VOA Learning English"
category_name = "科学与技术"
category_en = "Science and Technology"
category_slug = "science-technology"
tags = "voa,learning english,science,technology"
# Optional. Overrides [rss].max_items_per_feed for this feed.
# max_items = 50
enabled = true

